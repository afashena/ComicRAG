    "version": "0.2.0",
    "configurations": [

        {
            "name": "Caption Panels",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/captioner/generate_caption_ollama.py",
            "cwd": "${workspaceFolder}",
            "env": {
                    "PYTHONPATH": "${workspaceFolder}"
                },
            "console": "integratedTerminal",
            "args": ""
        },
        {
            "name": "Make DB",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/vector_db/make_db.py",
            "cwd": "${workspaceFolder}",
            "env": {
                    "PYTHONPATH": "${workspaceFolder}"
                },
            "console": "integratedTerminal",
            "args": ""
        },
    ]
}